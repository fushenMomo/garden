thread = 8
harbor = 0
start = "console_main"
bootstrap = "snlua bootstrap"	-- The service for bootstrap
luaservice = "../console/?.lua;../common/?.lua;./service/?.lua;"
lualoader = "./lualib/loader.lua"

-- 给 require 用
