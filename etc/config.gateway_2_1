thread = 8
harbor = 0
start = "gateway_main"
bootstrap = "snlua bootstrap"
luaservice = "../gateway/?.lua;../common/?.lua;./service/?.lua;"
lualoader = "./lualib/loader.lua"

lua_path = "./lualib/?.lua;./lualib/?/init.lua;../?.lua"
lua_cpath = "./luaclib/?.so"

cpath = "./cservice/?.so"


nodename = "gateway"
cluster = "../etc/clustername.gateway_2_1"
server_id = 2
proc_id = 1
login_count = 2

daemon = "../log/gateway/gateway_2_1.pid"
logger = "../log/gateway/gateway_core_2_1.log"
logger_level = "INFO"

debug_console = 9033

gateway_port = 8891
gateway_maxclient = 1024
gateway_package_max = 8192

